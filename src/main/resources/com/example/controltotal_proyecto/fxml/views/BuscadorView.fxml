<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox
    xmlns="http://javafx.com/javafx"
    xmlns:fx="http://javafx.com/fxml"
    fx:controller="com.example.controltotal_proyecto.controller.BuscadorController"
    styleClass="view-root">

    <VBox styleClass="page-header">
        <padding><Insets top="24" right="28" bottom="0" left="28"/></padding>
        <Label text="Buscador Avanzado" styleClass="page-title"/>
        <Label text="Búsqueda combinada de empresas y personas" styleClass="page-sub"/>
    </VBox>

    <HBox styleClass="toolbar" alignment="CENTER_LEFT" spacing="10">
        <padding><Insets top="16" right="28" bottom="0" left="28"/></padding>
        <HBox styleClass="search-box" maxWidth="500" HBox.hgrow="ALWAYS" alignment="CENTER_LEFT" spacing="6">
            <padding><Insets top="0" right="12" bottom="0" left="10"/></padding>
            <Label text="🔍" styleClass="search-icon"/>
            <TextField fx:id="searchField"
                       promptText="Nombre, apellidos, denominación social, NIF/CIF…"
                       styleClass="search-input" HBox.hgrow="ALWAYS"/>
        </HBox>
        <Button text="Buscar" styleClass="btn,btn-secondary" onAction="#onBuscar"/>
        <Region HBox.hgrow="ALWAYS"/>
    </HBox>

    <HBox styleClass="filter-bar" alignment="CENTER_LEFT" spacing="8">
        <padding><Insets top="10" right="28" bottom="10" left="28"/></padding>
        <Label text="Tipo:" styleClass="filter-label"/>
        <ToggleButton fx:id="chipTodos"    text="Todos"    styleClass="filter-chip"/>
        <ToggleButton fx:id="chipEmpresas" text="Empresas" styleClass="filter-chip"/>
        <ToggleButton fx:id="chipPersonas" text="Personas" styleClass="filter-chip"/>
        <Label text="Servicio:" styleClass="filter-label"/>
        <ComboBox fx:id="comboServicio"   styleClass="filter-select" prefWidth="130"/>
        <ComboBox fx:id="comboDelegacion" styleClass="filter-select" prefWidth="180"/>
        <ComboBox fx:id="comboEstado"     styleClass="filter-select" prefWidth="160"/>
    </HBox>

    <ScrollPane VBox.vgrow="ALWAYS" fitToWidth="true" styleClass="results-scroll">
        <VBox fx:id="resultContainer" spacing="6" styleClass="result-container">
            <padding><Insets top="14" right="28" bottom="28" left="28"/></padding>
        </VBox>
    </ScrollPane>

</VBox>
